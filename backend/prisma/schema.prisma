generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}
// Tabel Profil User 
model Profile {
  id             String   @id @default(uuid())
  userId         String   @unique // UID dari Firebase
  email          String   @unique
  fullName       String?
  birthdate      DateTime?
  weight         Float?
  height         Float?
  goal           String?  @default("Stay Healthy")
  dailyCalories  Int?     @default(2000)
  proteinTarget  Int?     @default(100)
  userStatus     String?  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Tabel Master Makanan 
model Food {
  id           Int      @id @default(autoincrement())
  name         String
  calories     Float
  proteins     Float
  fat          Float
  carbohydrate Float
  image        String?
  foodCluster  Int      
}

model DailyLog {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @default(now()) 
  day       String   
  
  // nutrisi dari makanan yang diinput 
  calories  Float    @default(0)
  proteins  Float    @default(0)
  fat       Float    @default(0)
  carbs     Float    @default(0)
  
  foodName  String?

  @@index([userId, day]) 
}

// Tabel AI Insights 
model DailyInsight {
  id        String   @id @default(uuid())
  userId    String
  text      String   @db.Text 
  createdAt DateTime @default(now())

  @@index([userId]) 
}